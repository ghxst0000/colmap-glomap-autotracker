# ============================================================
# Photogeometry Autotracker — Settings
# Copy this file to .env and adjust as needed.
# ============================================================

# Frames per second to extract from each video.
# Lower = fewer frames, faster processing, less memory.
# Higher = more frames, better reconstruction, more memory.
# Recommended range: 2–8 for most footage.
# Set to 0 to extract every frame at the video's native fps (high memory usage).
EXTRACT_FPS=4

# Max number of SIFT features detected per image.
# Lower = faster, less memory. Higher = more detail.
SIFT_MAX_NUM_FEATURES=8192

# Max image dimension (pixels) fed to SIFT.
# Larger images give more detail but use more memory.
SIFT_MAX_IMAGE_SIZE=3200

# Number of CPU threads for SIFT extraction and matching.
# Set to number of CPU cores you want to dedicate.
SIFT_NUM_THREADS=4

# Number of overlapping frames for sequential matching.
# Higher = more connections between frames, slower matching.
SEQUENTIAL_OVERLAP=15
