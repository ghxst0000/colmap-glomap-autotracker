# ── macOS ────────────────────────────────────────────────────
.DS_Store

# ── Environment (contains local overrides; use .env.sample as template) ──
.env

# ── Input videos (large binary files) ────────────────────────
videos/*
!videos/.gitkeep

# ── Reconstruction output (generated by the pipeline) ────────
scenes/*
!scenes/.gitkeep
